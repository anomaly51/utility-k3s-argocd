        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{cluster=\"workload-2-k3s\", namespace=\"architect-business-bot\", app=\"architect-business-bot\", container=\"bot\"} |~ \"$log_search\"",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
